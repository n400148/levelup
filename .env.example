# Supabase project settings — safe to expose to the client (RLS enforces access).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Google AI Studio key for the Insights AI coach. Server-only — read by
# src/app/api/ai/coach and src/app/api/ai/test, never referenced client-side.
GEMINI_KEY=your-gemini-api-key
